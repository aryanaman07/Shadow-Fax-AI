{
  "manifest_version": 3,
  "name": "ShadowPrompt",
  "version": "1.0",
  "permissions": ["scripting"],
  "host_permissions": ["https://chatgpt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources":[
    {
      "resources": ["injected.js"],
      "matches": ["https://chatgpt.com/*"]
    }
  ]
}